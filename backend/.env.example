# Single Last.fm API key. Required unless you set LASTFM_API_KEYS below.
LASTFM_API_KEY=your_lastfm_api_key_here
# Optional: comma-separated pool of owner keys (overrides LASTFM_API_KEY for
# the pool — more keys = more aggregate Last.fm rate limit).
LASTFM_API_KEYS=
# Optional: file path on a persistent disk where opt-in user-contributed keys
# (POST /api/keys) are saved and reloaded on boot. Unset → pool is in-memory
# and contributions reset on restart.
KEY_STORE_PATH=
# CORS allow-origin. Must match the frontend's URL exactly or the browser
# blocks responses. Default dev behavior (unset) allows any localhost.
FRONTEND_URL=http://localhost:3000
# Optional: enable the Redis-backed result cache. When unset, an in-memory
# cache is used (unchanged default behavior). Example: redis://localhost:6379
REDIS_URL=

# Optional: enables Postgres persistence (identity, events, saved/dismissed
# artists, listener observations). When unset, every persistence endpoint
# hides or 503s and discovery behaves byte-identically to before this
# feature shipped (graceful fallback). Matches the docker-compose `postgres`
# service: run `docker compose up -d postgres` then uncomment this.
# DATABASE_URL=postgres://postgres:dev@localhost:5433/postgres

# Optional: enables Last.fm login (POST /api/auth/session). Without it the
# endpoint returns 503 and the frontend hides the login entry. Get a secret
# for your API key at https://www.last.fm/api/accounts
LASTFM_API_SECRET=

# Optional: enable direct Spotify artist links and the /api/spotify/track
# preview endpoint. Without them, the app falls back to Spotify-search links
# and /api/spotify/track returns 404 (expected, not an error).
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Optional: listen port. Defaults to 8080 (Railway sets this itself).
PORT=
